@inherits LayoutComponentBase

@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<div>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid px-3">
            <a class="navbar-brand" href="#hero">@L["NavMenu_BackToTop"]</a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav" @onclick="CloseMenu">
                <div class="navbar-nav ms-auto align-items-end">
                    <br />
                    <a class="nav-link" href="#about">@L["Nav_About"]</a>
                    <a class="nav-link" href="#techstack">@L["Nav_TechStack"]</a>
                    <a class="nav-link" href="#projects">@L["Nav_Projects"]</a>
                    <a class="nav-link" href="#contact">@L["Nav_Contact"]</a>

                    <button class="btn btn-dark nav-lang-button" @onclick='() => ChangeLanguage("en")'>
                        🇬🇧 English
                    </button>
                    <button class="btn btn-dark nav-lang-button" @onclick='() => ChangeLanguage("fi")'>
                        🇫🇮 Suomi
                    </button>
                </div>
            </div>

        </div>
    </nav>

    <main>
        <div>
            @Body
        </div>
    </main>
</div>

@code {
    private async Task ChangeLanguage(string culture)
    {
        await JS.InvokeVoidAsync("cultureManager.set", culture);
    }

    private async Task CloseMenu()
    {
        await JS.InvokeVoidAsync("navHelper.closeMenu");
    }
}